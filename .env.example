# API and worker runtime
JDBC_URL=jdbc:postgresql://localhost:5432/copilot
JDBC_USERNAME=copilot
JDBC_PASSWORD=copilot
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=copilot-documents
MAX_UPLOAD_FILE_SIZE=25MB
MAX_UPLOAD_REQUEST_SIZE=26MB
COPILOT_MAX_FILE_SIZE_BYTES=26214400

# Local development: deterministic hash embeddings, no external embedding API key required.
COPILOT_EMBEDDING_PROVIDER=hash
COPILOT_EMBEDDING_MODEL=text-embedding-3-small
COPILOT_EMBEDDING_DIMENSIONS=1536
COPILOT_EMBEDDING_BATCH_SIZE=32
SPRING_AI_EMBEDDING_MODEL=none

# Chat is explicitly disabled by default. A chat request returns 503 until enabled.
COPILOT_CHAT_PROVIDER=none
SPRING_AI_CHAT_MODEL=none
COPILOT_CHAT_MODEL=gpt-5-mini
COPILOT_CHAT_TEMPERATURE=0.1
COPILOT_CHAT_MAX_EVIDENCE_CHARACTERS=12000

# Production OpenAI configuration. Keep this value in server secrets, never in Git.
# COPILOT_EMBEDDING_PROVIDER=openai
# SPRING_AI_EMBEDDING_MODEL=openai
# COPILOT_CHAT_PROVIDER=openai
# SPRING_AI_CHAT_MODEL=openai
# OPENAI_API_KEY=replace-with-secret
