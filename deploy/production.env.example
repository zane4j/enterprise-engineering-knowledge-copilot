# Public hostname. DNS A/AAAA records must point to this server before Caddy starts.
DOMAIN=rag.example.com
APP_IMAGE_TAG=replace-with-git-commit-sha

POSTGRES_USER=copilot
POSTGRES_PASSWORD=replace-with-a-long-random-password
JDBC_USERNAME=copilot
JDBC_PASSWORD=replace-with-the-same-long-random-password

MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-a-long-random-minio-secret
MINIO_BUCKET=copilot-documents

# Production LLM. Keep this file on the server; never commit it.
OPENAI_API_KEY=replace-with-server-secret
COPILOT_EMBEDDING_PROVIDER=openai
SPRING_AI_EMBEDDING_MODEL=openai
COPILOT_EMBEDDING_MODEL=text-embedding-3-small
COPILOT_EMBEDDING_DIMENSIONS=1536
COPILOT_CHAT_PROVIDER=openai
SPRING_AI_CHAT_MODEL=openai
COPILOT_CHAT_MODEL=gpt-5-mini
COPILOT_CHAT_TEMPERATURE=0.1
